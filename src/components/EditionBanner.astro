---
import { editionsListing } from "../data/editions";

const editions = editionsListing;
---

<section class="edition-banner">
  <div class="container">
    <div class="banner-header">
      <h2 class="banner-title">THE MAGAZINE</h2>
      <div class="banner-controls">
        <button class="arrow-btn" id="prevBtn" aria-label="Previous">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="arrow-btn" id="nextBtn" aria-label="Next">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <div class="editions-wrapper">
      <div class="editions-scroll" id="editionsScroll">
        {editions.map((edition) => (
          <a href={`/ediciones/${edition.slug}`} class="edition-card">
            <div class="edition-cover">
              <div class="edition-image-container">
                <img 
                  src={edition.coverImage} 
                  alt={`${edition.title} Cover`}
                  class="edition-img"
                  loading="lazy"
                />
              </div>
            </div>
            <h3 class="edition-title">{edition.title}</h3>
            <p class="edition-subtitle">{edition.month} {edition.year}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>


<style>
  .edition-banner {
    padding: var(--space-12) 0;
    background-color: var(--color-white);
    border-top: var(--border-width) solid var(--border-color);
    border-bottom: var(--border-width) solid var(--border-color);
  }

  .banner-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .banner-title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .banner-controls {
    display: flex;
    gap: var(--space-2);
  }

  .arrow-btn {
    background: none;
    border: var(--border-width) solid var(--color-black);
    padding: var(--space-2);
    cursor: pointer;
    color: var(--color-black);
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
  }

  .arrow-btn:hover {
    background-color: var(--color-black);
    color: var(--color-white);
  }

  .editions-wrapper {
    overflow: hidden;
  }

  .editions-scroll {
    display: flex;
    gap: var(--space-6);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .editions-scroll::-webkit-scrollbar {
    display: none;
  }

  .edition-card {
    flex: 0 0 auto;
    width: 200px;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .edition-cover {
    margin-bottom: var(--space-3);
    overflow: hidden;
  }

  .edition-image-container {
    width: 100%;
    height: 280px;
    background-color: var(--color-gray-100);
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-base);
  }

  .edition-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .edition-card:hover .edition-image-container {
    transform: translateY(-4px);
  }

  .edition-card:hover .edition-img {
    transform: scale(1.05);
  }

  .edition-title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-1);
    color: var(--color-black);
  }

  .edition-subtitle {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .edition-card {
      width: 240px;
    }

    .edition-image-container {
      height: 340px;
    }

    .banner-title {
      font-size: var(--text-3xl);
    }
  }

  @media (min-width: 1024px) {
    .edition-card {
      width: 280px;
    }

    .edition-image-container {
      height: 400px;
    }
  }
</style>

<script>
  const editionsScroll = document.getElementById("editionsScroll");
  const prevBtn = document.getElementById("prevBtn");
  const nextBtn = document.getElementById("nextBtn");

  if (editionsScroll && prevBtn && nextBtn) {
    const scrollAmount = 300;

    prevBtn.addEventListener("click", () => {
      editionsScroll.scrollBy({
        left: -scrollAmount,
        behavior: "smooth",
      });
    });

    nextBtn.addEventListener("click", () => {
      editionsScroll.scrollBy({
        left: scrollAmount,
        behavior: "smooth",
      });
    });
  }
</script>
