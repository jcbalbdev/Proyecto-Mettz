<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <!-- Newsletter Section -->
      <div class="footer-section newsletter-section">
        <h3 class="footer-title">Mantente Actualizado</h3>
        <p class="footer-text">
          Suscríbete a nuestro newsletter para recibir las últimas novedades
          sobre moda y cine.
        </p>
        <form class="newsletter-form">
          <input
            type="email"
            placeholder="Ingresa tu email"
            class="newsletter-input"
            required
          />
          <button type="submit" class="btn btn-sm">Suscribirse</button>
        </form>
      </div>

      <!-- Quick Links -->
      <div class="footer-section">
        <h4 class="footer-heading">Enlaces Rápidos</h4>
        <ul class="footer-links">
          <li><a href="/ediciones">Ediciones</a></li>
          <li><a href="/photomettz">PhotoMettz</a></li>
          <li><a href="/video">Video</a></li>
          <li><a href="/podcast">Podcast</a></li>
        </ul>
      </div>

      <!-- About -->
      <div class="footer-section">
        <h4 class="footer-heading">Acerca de</h4>
        <ul class="footer-links">
          <li><a href="/mettzglobal">Mettz Global</a></li>
          <li><a href="/agencia">Agencia</a></li>
          <li><a href="/talentos">Talentos Emergentes</a></li>
        </ul>
      </div>

      <!-- Social Media -->
      <div class="footer-section">
        <h4 class="footer-heading">Síguenos</h4>
        <div class="social-links">
          <a href="#" aria-label="Instagram">Instagram</a>
          <a href="#" aria-label="Twitter">Twitter</a>
          <a href="#" aria-label="Facebook">Facebook</a>
          <a href="#" aria-label="YouTube">YouTube</a>
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p class="copyright">
        © 2026 METTZ Magazine. Todos los derechos reservados.
      </p>
      <div class="footer-legal">
        <a href="/privacy">Política de Privacidad</a>
        <a href="/terms">Términos de Servicio</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-black);
    color: var(--color-white);
    padding: var(--space-12) 0 var(--space-6);
    margin-top: var(--space-20);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: var(--border-width) solid rgba(255, 255, 255, 0.1);
  }

  .newsletter-section {
    grid-column: 1 / -1;
  }

  .footer-title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-3);
  }

  .footer-text {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-3);
    max-width: 400px;
  }

  .newsletter-input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    background-color: rgba(255, 255, 255, 0.1);
    border: var(--border-width) solid rgba(255, 255, 255, 0.2);
    color: var(--color-white);
    font-size: var(--text-sm);
    transition: border-color var(--transition-fast);
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-white);
  }

  .footer-heading {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-2);
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-white);
    opacity: 1;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .social-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .social-links a:hover {
    color: var(--color-white);
    opacity: 1;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    text-align: center;
  }

  .copyright {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  .footer-legal {
    display: flex;
    gap: var(--space-4);
  }

  .footer-legal a {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
    transition: color var(--transition-fast);
  }

  .footer-legal a:hover {
    color: var(--color-white);
    opacity: 1;
  }

  @media (min-width: 640px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr);
    }

    .social-links {
      flex-direction: row;
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  @media (min-width: 1024px) {
    .footer-content {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }

    .newsletter-section {
      grid-column: auto;
    }
  }
</style>
