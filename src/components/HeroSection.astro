---
interface Props {
  category: string;
  title: string;
  description?: string;
  imageUrl?: string;
  link: string;
}

const { category, title, description, imageUrl, link } = Astro.props;
---

<article class="hero-section">
  <a href={link} class="hero-link">
    {
      imageUrl && (
        <div class="hero-image-wrapper">
          <img src={imageUrl} alt={title} class="hero-image" />
        </div>
      )
    }
    <div class="hero-content">
      <span class="category-badge">{category}</span>
      <h2 class="hero-title">{title}</h2>
      {description && <p class="hero-description">{description}</p>}
      <span class="read-more">Read More →</span>
    </div>
  </a>
</article>

<style>
  .hero-section {
    margin-bottom: var(--space-12);
  }

  .hero-link {
    display: block;
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 60%; /* 5:3 aspect ratio */
    background-color: var(--color-gray-200);
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .hero-link:hover .hero-image {
    transform: scale(1.05);
  }

  .hero-content {
    padding: var(--space-6) 0;
  }

  .category-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: var(--color-black);
    color: var(--color-white);
    margin-bottom: var(--space-3);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-gray-600);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .read-more {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-black);
    transition: opacity var(--transition-fast);
  }

  .hero-link:hover .read-more {
    opacity: 0.6;
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: var(--text-5xl);
    }

    .hero-description {
      font-size: var(--text-xl);
    }
  }
</style>
