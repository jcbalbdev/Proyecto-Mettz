---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import MobileMenu from "../../components/MobileMenu.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Issue 12: Winter Reflections - METTZ">
  <Header />
  <MobileMenu />

  <main class="edition-page">
    <!-- Hero Section with Cover -->
    <section class="edition-hero">
      <div class="hero-background">
        <div class="hero-overlay">
          <div class="container">
            <div class="hero-content">
              <span class="issue-label">Issue 12</span>
              <h1 class="edition-title">Winter Reflections</h1>
              <p class="edition-season">Invierno 2026</p>
              <p class="edition-tagline">
                Una exploración íntima de la moda invernal, el cine
                contemplativo y la belleza en la quietud
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Introduction / Storytelling Start -->
    <section class="story-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">Una Historia de Quietud</h2>
          <p class="story-paragraph lead">
            En esta edición de invierno, exploramos la belleza que emerge cuando
            el mundo se detiene. Desde las pasarelas de Milán hasta los estudios
            cinematográficos de Berlín, capturamos momentos de contemplación,
            elegancia atemporal y creatividad pura.
          </p>
        </div>
      </div>
    </section>

    <!-- Image Section 1 -->
    <section class="visual-section">
      <div class="visual-full">
        <div
          class="image-placeholder"
          style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); height: 70vh;"
        >
          <!-- Featured editorial image -->
        </div>
        <p class="image-caption">
          Editorial exclusivo: "Siluetas en la Nieve" - Fotografía por André
          Bergman
        </p>
      </div>
    </section>

    <!-- Story Content 1 -->
    <section class="story-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">Minimalismo Invernal</h2>
          <p class="story-paragraph">
            Esta temporada, los diseñadores abrazan la simplicidad radical.
            Texturas ricas en tonos neutros, siluetas limpias que desafían el
            exceso, y una artesanía que habla por sí misma. Nuestra portada
            presenta a la modelo Sasha Ivanova en creaciones de The Row, Jil
            Sander y Lemaire, fotografiada en las montañas nevadas de Suiza.
          </p>
        </div>
      </div>
    </section>

    <!-- Image Grid Section -->
    <section class="visual-section">
      <div class="container">
        <div class="image-grid">
          <div class="grid-item grid-large">
            <div
              class="image-placeholder"
              style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); height: 500px;"
            >
            </div>
            <p class="image-caption">
              Detalles de construcción: costuras invisibles
            </p>
          </div>
          <div class="grid-item">
            <div
              class="image-placeholder"
              style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); height: 240px;"
            >
            </div>
            <p class="image-caption">Paleta de colores: grises y blancos</p>
          </div>
          <div class="grid-item">
            <div
              class="image-placeholder"
              style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); height: 240px;"
            >
            </div>
            <p class="image-caption">Texturas: cachemira y lana merino</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Story Content 2 -->
    <section class="story-section dark-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">Conversaciones Cinematográficas</h2>
          <p class="story-paragraph">
            Entrevistamos a la directora María González sobre su última película
            "Silencio Blanco", un estudio contemplativo sobre aislamiento y
            conexión humana. Su enfoque minimalista del cine refleja
            perfectamente la estética de esta edición: menos diálogo, más
            emoción; menos movimiento, más significado.
          </p>
          <blockquote class="story-quote">
            "El invierno nos enseña que la belleza no necesita gritar. Puede
            susurrar a través del silencio."
            <cite>— María González</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Full Width Visual -->
    <section class="visual-section">
      <div class="visual-full">
        <div
          class="image-placeholder"
          style="background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); height: 80vh;"
        >
          <!-- Behind the scenes cinema -->
        </div>
        <p class="image-caption">
          Behind the scenes: Rodaje de "Silencio Blanco" en Islandia
        </p>
      </div>
    </section>

    <!-- Featured Articles Preview -->
    <section class="story-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">En Esta Edición</h2>
          <div class="featured-list">
            <div class="featured-item">
              <h3>Guardarropa Cápsula: Invierno Esencial</h3>
              <p>
                Las 15 piezas que necesitas para un invierno elegante y
                sostenible
              </p>
            </div>
            <div class="featured-item">
              <h3>Directores Visionarios: Nueva Generación</h3>
              <p>
                Cinco cineastas redefiniendo el lenguaje visual del cine
                contemporáneo
              </p>
            </div>
            <div class="featured-item">
              <h3>PhotoMettz: Editorial Blanco sobre Blanco</h3>
              <p>Una sesión fotográfica experimental en los Alpes suizos</p>
            </div>
            <div class="featured-item">
              <h3>Artesanía Moderna: Los Nuevos Maestros</h3>
              <p>
                Conoce a los artesanos detrás de las marcas de lujo más
                codiciadas
              </p>
            </div>
            <div class="featured-item">
              <h3>Cultura: Arte en el Hielo</h3>
              <p>Esculturas efímeras y la belleza de lo temporal</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final Image -->
    <section class="visual-section">
      <div class="visual-full">
        <div
          class="image-placeholder"
          style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); height: 60vh;"
        >
          <!-- Closing image -->
        </div>
        <p class="image-caption">
          Conclusión visual: La quietud como declaración de moda
        </p>
      </div>
    </section>

    <!-- Call to Action - Download/Share -->
    <section class="edition-cta">
      <div class="container-narrow">
        <div class="cta-content">
          <h2 class="cta-title">Explora la Edición Completa</h2>
          <p class="cta-text">
            Descubre todas las historias, editoriales fotográficos y contenido
            exclusivo de Winter Reflections en formato digital.
          </p>

          <div class="cta-buttons">
            <a href="#" class="btn btn-large btn-primary" download>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Descargar PDF Completo
            </a>
            <button class="btn btn-large btn-outline" id="shareButton">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
              </svg>
              Compartir Edición
            </button>
          </div>

          <!-- Share Menu (Hidden by default) -->
          <div class="share-menu" id="shareMenu" style="display: none;">
            <button class="share-option" data-platform="twitter">
              Compartir en Twitter
            </button>
            <button class="share-option" data-platform="facebook">
              Compartir en Facebook
            </button>
            <button class="share-option" data-platform="linkedin">
              Compartir en LinkedIn
            </button>
            <button class="share-option" data-platform="copy">
              Copiar enlace
            </button>
          </div>

          <a href="/ediciones" class="back-link"
            >← Volver a todas las ediciones</a
          >
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .edition-page {
    background-color: var(--color-white);
  }

  /* Hero Section */
  .edition-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }

  .hero-background {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
  }

  .hero-overlay {
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-content {
    color: var(--color-white);
  }

  .issue-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-3);
    opacity: 0.9;
  }

  .edition-title {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1.1;
    margin-bottom: var(--space-3);
    font-weight: 400;
  }

  .edition-season {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
    opacity: 0.9;
  }

  .edition-tagline {
    font-size: var(--text-lg);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.95;
  }

  /* Story Sections */
  .story-section {
    padding: var(--space-16) 0;
  }

  .dark-section {
    background-color: var(--color-gray-100);
  }

  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .story-text {
    text-align: left;
  }

  .story-heading {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
    color: var(--color-black);
  }

  .story-paragraph {
    font-size: var(--text-xl);
    line-height: 1.8;
    color: var(--color-gray-700);
    margin-bottom: var(--space-6);
  }

  .story-paragraph.lead {
    font-size: var(--text-2xl);
    color: var(--color-gray-800);
  }

  .story-quote {
    margin: var(--space-10) 0;
    padding: var(--space-8);
    background-color: var(--color-white);
    border-left: 4px solid var(--color-black);
    font-size: var(--text-2xl);
    font-style: italic;
    line-height: 1.6;
  }

  .story-quote cite {
    display: block;
    margin-top: var(--space-4);
    font-size: var(--text-base);
    font-style: normal;
    font-weight: 600;
    color: var(--color-gray-600);
  }

  /* Visual Sections */
  .visual-section {
    margin: var(--space-12) 0;
  }

  .visual-full {
    width: 100%;
  }

  .image-placeholder {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    font-size: var(--text-lg);
  }

  .image-caption {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    font-style: italic;
    margin-top: var(--space-3);
    padding: 0 var(--container-padding);
  }

  .image-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: 0 var(--container-padding);
  }

  .grid-item {
    position: relative;
  }

  /* Featured List */
  .featured-list {
    margin-top: var(--space-8);
  }

  .featured-item {
    padding: var(--space-6) 0;
    border-bottom: var(--border-width) solid var(--border-color);
  }

  .featured-item:last-child {
    border-bottom: none;
  }

  .featured-item h3 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
    color: var(--color-black);
  }

  .featured-item p {
    font-size: var(--text-base);
    color: var(--color-gray-600);
    margin: 0;
  }

  /* CTA Section */
  .edition-cta {
    background-color: var(--color-gray-100);
    padding: var(--space-16) 0;
    text-align: center;
  }

  .cta-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .cta-text {
    font-size: var(--text-xl);
    color: var(--color-gray-600);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .btn-large {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-lg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .btn-primary {
    background-color: var(--color-black);
    color: var(--color-white);
    border: var(--border-width) solid var(--color-black);
  }

  .btn-primary:hover {
    background-color: var(--color-gray-800);
  }

  .share-menu {
    background-color: var(--color-white);
    border: var(--border-width) solid var(--border-color);
    padding: var(--space-2);
    margin-top: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .share-option {
    display: block;
    width: 100%;
    padding: var(--space-3) var(--space-4);
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-base);
    transition: background-color var(--transition-fast);
  }

  .share-option:hover {
    background-color: var(--color-gray-100);
  }

  .back-link {
    display: inline-block;
    margin-top: var(--space-6);
    color: var(--color-gray-600);
    font-size: var(--text-base);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-black);
  }

  /* Responsive */
  @media (min-width: 640px) {
    .cta-buttons {
      flex-direction: row;
      justify-content: center;
    }

    .image-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid-large {
      grid-column: span 2;
    }
  }

  @media (max-width: 639px) {
    .edition-title {
      font-size: 3rem;
    }

    .story-heading {
      font-size: var(--text-3xl);
    }

    .story-paragraph {
      font-size: var(--text-lg);
    }

    .story-paragraph.lead {
      font-size: var(--text-xl);
    }

    .cta-title {
      font-size: var(--text-3xl);
    }
  }
</style>

<script>
  // Share button functionality
  const shareButton = document.getElementById("shareButton");
  const shareMenu = document.getElementById("shareMenu");
  const shareOptions = document.querySelectorAll(".share-option");

  shareButton?.addEventListener("click", () => {
    if (shareMenu) {
      shareMenu.style.display =
        shareMenu.style.display === "none" ? "block" : "none";
    }
  });

  shareOptions.forEach((option) => {
    option.addEventListener("click", (e) => {
      const platform = (e.target as HTMLElement).getAttribute("data-platform");
      const url = window.location.href;
      const title = "METTZ - Winter Reflections Issue 12";

      switch (platform) {
        case "twitter":
          window.open(
            `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`,
            "_blank",
          );
          break;
        case "facebook":
          window.open(
            `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
            "_blank",
          );
          break;
        case "linkedin":
          window.open(
            `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
            "_blank",
          );
          break;
        case "copy":
          navigator.clipboard.writeText(url);
          alert("¡Enlace copiado al portapapeles!");
          break;
      }

      if (shareMenu) {
        shareMenu.style.display = "none";
      }
    });
  });

  // Close share menu when clicking outside
  document.addEventListener("click", (e) => {
    if (
      shareMenu &&
      shareButton &&
      !shareButton.contains(e.target as Node) &&
      !shareMenu.contains(e.target as Node)
    ) {
      shareMenu.style.display = "none";
    }
  });
</script>
