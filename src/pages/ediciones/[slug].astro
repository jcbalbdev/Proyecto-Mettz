---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import MobileMenu from "../../components/MobileMenu.astro";
import Footer from "../../components/Footer.astro";
import { editionsDetail } from "../../data/editions";
import type { EditionDetail } from "../../data/editions";

export function getStaticPaths() {
  return editionsDetail.map((edition) => ({
    params: { slug: edition.slug },
    props: { edition },
  }));
}

interface Props {
  edition: EditionDetail;
}

const { edition } = Astro.props;
const shareTitle = `METTZ - ${edition.title} ${edition.issueNumber}`;
---

<Layout title={`${edition.issueNumber}: ${edition.title} - METTZ`}>
  <Header />
  <MobileMenu />

  <main class="edition-page">
    <!-- Hero Section with Cover -->
    <section class="edition-hero">
      <div class="hero-background">
        <img
          src={edition.heroImage.src}
          alt={edition.heroImage.alt}
          class="hero-bg-image"
        />
        <div class="hero-overlay">
          <div class="container">
            <div class="hero-content">
              <span class="issue-label">{edition.issueNumber}</span>
              <h1 class="edition-title">{edition.title}</h1>
              <p class="edition-date">{edition.month} {edition.year}</p>
              <p class="edition-tagline">{edition.tagline}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Introduction -->
    <section class="story-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">{edition.intro.heading}</h2>
          <p class="story-paragraph lead">{edition.intro.paragraph}</p>
        </div>
      </div>
    </section>

    <!-- Featured Image -->
    <section class="visual-section">
      <div class="visual-full">
        <img
          src={edition.featuredImage.src}
          alt={edition.featuredImage.alt}
          class="editorial-image"
          style="height: 70vh; width: 100%; object-fit: cover;"
        />
        <p class="image-caption">{edition.featuredImage.caption}</p>
      </div>
    </section>

    <!-- Story Content -->
    <section class="story-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">{edition.story.heading}</h2>
          <p class="story-paragraph">{edition.story.paragraph}</p>
        </div>
      </div>
    </section>

    <!-- Image Grid -->
    <section class="visual-section">
      <div class="container">
        <div class="image-grid">
          <div class="grid-item grid-large">
            <img
              src={edition.gridImages.large.src}
              alt={edition.gridImages.large.alt}
              class="editorial-image"
              style="height: 500px; width: 100%; object-fit: cover;"
            />
            <p class="image-caption">{edition.gridImages.large.caption}</p>
          </div>
          <div class="grid-item">
            <img
              src={edition.gridImages.small1.src}
              alt={edition.gridImages.small1.alt}
              class="editorial-image"
              style="height: 240px; width: 100%; object-fit: cover; object-position: top;"
            />
            <p class="image-caption">{edition.gridImages.small1.caption}</p>
          </div>
          <div class="grid-item">
            <img
              src={edition.gridImages.small2.src}
              alt={edition.gridImages.small2.alt}
              class="editorial-image"
              style="height: 240px; width: 100%; object-fit: cover;"
            />
            <p class="image-caption">{edition.gridImages.small2.caption}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Dark Section with Quote -->
    <section class="story-section dark-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">{edition.darkSection.heading}</h2>
          <p class="story-paragraph">{edition.darkSection.paragraph}</p>
          <blockquote class="story-quote">
            {edition.quote.text}
            <cite>{edition.quote.cite}</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Full Width Visual -->
    <section class="visual-section">
      <div class="visual-full">
        <img
          src={edition.fullWidthImage.src}
          alt={edition.fullWidthImage.alt}
          class="editorial-image"
          style="height: 80vh; width: 100%; object-fit: cover; object-position: center 30%;"
        />
        <p class="image-caption">{edition.fullWidthImage.caption}</p>
      </div>
    </section>

    <!-- Featured Articles -->
    <section class="story-section">
      <div class="container-narrow">
        <div class="story-text">
          <h2 class="story-heading">En Esta Edición</h2>
          <div class="featured-list">
            {edition.featuredArticles.map((article) => (
              <a href={article.href} class="featured-item">
                <h3>{article.title}</h3>
                <p>{article.description}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Closing Image -->
    <section class="visual-section">
      <div class="visual-full">
        <img
          src={edition.closingImage.src}
          alt={edition.closingImage.alt}
          class="editorial-image"
          style="height: 60vh; width: 100%; object-fit: cover;"
        />
        <p class="image-caption">{edition.closingImage.caption}</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="edition-cta">
      <div class="container-narrow">
        <div class="cta-content">
          <h2 class="cta-title">Explora la Edición Completa</h2>
          <p class="cta-text">{edition.ctaDescription}</p>

          <div class="cta-buttons">
            <a href={edition.pdfPath} class="btn btn-large btn-primary" download>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Descargar PDF Completo
            </a>
            <button class="btn btn-large btn-outline" id="shareButton">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
              </svg>
              Compartir Edición
            </button>
          </div>

          <div class="share-menu" id="shareMenu" style="display: none;">
            <button class="share-option" data-platform="twitter">Compartir en Twitter</button>
            <button class="share-option" data-platform="facebook">Compartir en Facebook</button>
            <button class="share-option" data-platform="linkedin">Compartir en LinkedIn</button>
            <button class="share-option" data-platform="copy">Copiar enlace</button>
          </div>

          <a href="/ediciones" class="back-link">← Volver a todas las ediciones</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .edition-page { background-color: var(--color-white); }

  .edition-hero { position: relative; height: 100vh; min-height: 600px; overflow: hidden; }
  .hero-background { width: 100%; height: 100%; position: relative; }
  .hero-bg-image { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; }
  .hero-overlay {
    position: relative; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%);
    display: flex; align-items: center; justify-content: center; text-align: center; z-index: 1;
  }
  .hero-content { color: var(--color-white); }
  .issue-label { display: inline-block; font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: var(--space-3); opacity: 0.9; }
  .edition-title { font-size: clamp(3rem, 8vw, 6rem); line-height: 1.1; margin-bottom: var(--space-3); font-weight: 400; }
  .edition-date { font-size: var(--text-xl); margin-bottom: var(--space-4); opacity: 0.9; }
  .edition-tagline { font-size: var(--text-lg); max-width: 700px; margin: 0 auto; line-height: 1.6; opacity: 0.95; }

  .story-section { padding: var(--space-16) 0; }
  .dark-section { background-color: var(--color-gray-100); }
  .container-narrow { max-width: 800px; margin: 0 auto; padding: 0 var(--container-padding); }
  .story-text { text-align: left; }
  .story-heading { font-size: var(--text-4xl); margin-bottom: var(--space-6); color: var(--color-black); }
  .story-paragraph { font-size: var(--text-xl); line-height: 1.8; color: var(--color-gray-700); margin-bottom: var(--space-6); }
  .story-paragraph.lead { font-size: var(--text-2xl); color: var(--color-gray-800); }
  .story-quote { margin: var(--space-10) 0; padding: var(--space-8); background-color: var(--color-white); border-left: 4px solid var(--color-black); font-size: var(--text-2xl); font-style: italic; line-height: 1.6; }
  .story-quote cite { display: block; margin-top: var(--space-4); font-size: var(--text-base); font-style: normal; font-weight: 600; color: var(--color-gray-600); }

  .visual-section { margin: var(--space-12) 0; }
  .visual-full { width: 100%; }
  .editorial-image { display: block; }
  .image-caption { text-align: center; font-size: var(--text-sm); color: var(--color-gray-600); font-style: italic; margin-top: var(--space-3); padding: 0 var(--container-padding); }
  .image-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); padding: 0 var(--container-padding); }
  .grid-item { position: relative; }

  .featured-list { margin-top: var(--space-8); }
  .featured-item { display: block; padding: var(--space-6) 0; border-bottom: var(--border-width) solid var(--border-color); text-decoration: none; color: inherit; transition: opacity var(--transition-fast); }
  .featured-item:hover { opacity: 0.7; }
  .featured-item:last-child { border-bottom: none; }
  .featured-item h3 { font-family: var(--font-serif); font-size: var(--text-2xl); font-weight: 400; margin-bottom: var(--space-2); color: var(--color-black); }
  .featured-item p { font-size: var(--text-base); color: var(--color-gray-600); margin: 0; }

  .edition-cta { background-color: var(--color-gray-100); padding: var(--space-16) 0; text-align: center; }
  .cta-content { max-width: 700px; margin: 0 auto; }
  .cta-title { font-size: var(--text-4xl); margin-bottom: var(--space-4); }
  .cta-text { font-size: var(--text-xl); color: var(--color-gray-600); line-height: 1.6; margin-bottom: var(--space-8); }
  .cta-buttons { display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-8); }
  .btn-large { padding: var(--space-4) var(--space-8); font-size: var(--text-lg); display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2); }
  .btn-primary { background-color: var(--color-black); color: var(--color-white); border: var(--border-width) solid var(--color-black); }
  .btn-primary:hover { background-color: var(--color-gray-800); }

  .share-menu { background-color: var(--color-white); border: var(--border-width) solid var(--border-color); padding: var(--space-2); margin-top: var(--space-4); margin-bottom: var(--space-6); }
  .share-option { display: block; width: 100%; padding: var(--space-3) var(--space-4); text-align: left; background: none; border: none; cursor: pointer; font-size: var(--text-base); transition: background-color var(--transition-fast); }
  .share-option:hover { background-color: var(--color-gray-100); }
  .back-link { display: inline-block; margin-top: var(--space-6); color: var(--color-gray-600); font-size: var(--text-base); transition: color var(--transition-fast); }
  .back-link:hover { color: var(--color-black); }

  @media (min-width: 640px) {
    .cta-buttons { flex-direction: row; justify-content: center; }
    .image-grid { grid-template-columns: repeat(2, 1fr); }
    .grid-large { grid-column: span 2; }
  }
  @media (max-width: 639px) {
    .edition-title { font-size: 3rem; }
    .story-heading { font-size: var(--text-3xl); }
    .story-paragraph { font-size: var(--text-lg); }
    .story-paragraph.lead { font-size: var(--text-xl); }
    .cta-title { font-size: var(--text-3xl); }
  }
</style>

<script define:vars={{ shareTitle }}>
  // Share button functionality
  const shareButton = document.getElementById("shareButton");
  const shareMenu = document.getElementById("shareMenu");
  const shareOptions = document.querySelectorAll(".share-option");

  shareButton?.addEventListener("click", () => {
    if (shareMenu) {
      shareMenu.style.display = shareMenu.style.display === "none" ? "block" : "none";
    }
  });

  shareOptions.forEach((option) => {
    option.addEventListener("click", (e) => {
      const platform = e.target.getAttribute("data-platform");
      const url = window.location.href;

      switch (platform) {
        case "twitter":
          window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(shareTitle)}`, "_blank");
          break;
        case "facebook":
          window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, "_blank");
          break;
        case "linkedin":
          window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, "_blank");
          break;
        case "copy":
          navigator.clipboard.writeText(url);
          alert("¡Enlace copiado al portapapeles!");
          break;
      }

      if (shareMenu) { shareMenu.style.display = "none"; }
    });
  });

  document.addEventListener("click", (e) => {
    if (shareMenu && shareButton && !shareButton.contains(e.target) && !shareMenu.contains(e.target)) {
      shareMenu.style.display = "none";
    }
  });
</script>
